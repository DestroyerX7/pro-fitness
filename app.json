{
  "expo": {
    "name": "Pro Fitness",
    "slug": "pro-fitness",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "profitness",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": {
        "dark": "./assets/images/ios-icon-dark.png",
        "light": "./assets/images/ios-icon-default.png",
        "tinted": "./assets/images/ios-icon-tinted.png"
      },
      "bundleIdentifier": "com.destroyerinc.profitness",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0080ff",
        "backgroundImage": "./assets//images/android-icon-background.png",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0080ff",
          "image": "./assets/images/icon.png",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#111111"
          },
          "imageWidth": 200
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Pro Fitness uses your camera so you can take photos for calorie logs, scan product barcodes, and update your profile picture."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pro Fitness uses your photo library so you can attach images to calorie logs and update your profile picture."
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c3843f25-1680-4cfb-8ee3-1fbe1e1d3602"
      }
    }
  }
}
